# ══════════════════════════════════════════════
# Configuration Environment Variables
# ══════════════════════════════════════════════
# Copier ce fichier vers .env et adapter les valeurs

# ── Config Server Git Repository ──
CONFIG_GIT_URI=https://github.com/votre-org/config.git
CONFIG_SEARCH_PATHS=config
CONFIG_GIT_BRANCH=main
CONFIG_GIT_USERNAME=
CONFIG_GIT_PASSWORD=

# ── Database ──
DB_URL=jdbc:postgresql://postgres:5432/votre_db
DB_USERNAME=user_svc
DB_PASSWORD=user_pass

# ── RabbitMQ ──
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=msuser_admin
RABBITMQ_PASSWORD=msuser_mdp

# ── Eureka ──
EUREKA_URL=http://eureka-server:8761/eureka/
